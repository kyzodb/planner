{
  "mcpServers": {
    "board": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CLAUDE_PLUGIN_ROOT}",
        "python",
        "${CLAUDE_PLUGIN_ROOT}/app/main.py"
      ],
      "env": {
        "PLAN_REPO": "${CLAUDE_PROJECT_DIR}",
        "PLAN_BOARD_OWNER": "${user_config.board_owner}",
        "PLAN_BOARD_REPO": "${user_config.board_repo}",
        "PLAN_BOARD_PROJECT": "${user_config.board_project}",
        "UV_PROJECT_ENVIRONMENT": "${CLAUDE_PLUGIN_ROOT}/.venv"
      }
    }
  }
}
